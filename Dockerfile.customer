# Customer Portal Dockerfile
FROM python:3.11-slim

# Create a non-root user for security
RUN groupadd -g 1000 spegroup && \
    useradd -u 1000 -g spegroup -m speuser

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt .
RUN pip install --no-cache-dir --default-timeout=1000 -r requirements.txt

COPY streamlit_customer.py .
COPY requirements.txt .
COPY data/ ./data/
RUN mkdir -p ./logs && chown -R speuser:spegroup /app

# Create Streamlit config directory in user's home
RUN mkdir -p /home/speuser/.streamlit && chown -R speuser:spegroup /home/speuser/.streamlit
COPY streamlit/config.toml /home/speuser/.streamlit/config.toml

# Switch to non-root user
USER speuser

EXPOSE 8504
ENV PYTHONUNBUFFERED=1

HEALTHCHECK --interval=30s --timeout=10s --start-period=40s --retries=3 \
    CMD curl -f http://localhost:8504/_stcore/health || exit 1

CMD ["streamlit", "run", "streamlit_customer.py", "--server.port=8504", "--server.address=0.0.0.0"]
