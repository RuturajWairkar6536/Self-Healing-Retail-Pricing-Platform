# Environment Variables Template
# Copy to .env and fill in your values
# NEVER commit .env to version control

# =======================
# Docker Compose Settings
# =======================
COMPOSE_PROJECT_NAME=spe-platform
COMPOSE_FILE=docker-compose.yml

# =======================
# PostgreSQL
# =======================
POSTGRES_DB=spe_platform
POSTGRES_USER=spe_user
POSTGRES_PASSWORD=spe_secure_password_change_me
POSTGRES_PORT=5432

# =======================
# Redis
# =======================
REDIS_URL=redis://redis:6379/0
REDIS_PASSWORD=

# =======================
# Flask API
# =======================
FLASK_ENV=production
FLASK_APP=app.py
SECRET_KEY=your-secret-key-generate-a-random-string-here
LOG_LEVEL=INFO
API_PORT=5001

# =======================
# Streamlit
# =======================
STREAMLIT_SERVER_HEADLESS=true
STREAMLIT_SERVER_ENABLEXSRFPROTECTION=true
API_URL=http://pricing-api:5001

# =======================
# Jenkins
# =======================
JENKINS_USER=admin
JENKINS_PASSWORD=change_me_in_production
JENKINS_PORT=8080

# =======================
# Docker Registry
# =======================
DOCKER_REGISTRY=docker.io
DOCKER_USERNAME=your_docker_username
DOCKER_PASSWORD=your_docker_password
DOCKER_EMAIL=your@email.com

# =======================
# Kubernetes
# =======================
KUBECONFIG=/path/to/kubeconfig
KUBE_NAMESPACE=spe-platform

# =======================
# CI/CD (Jenkins)
# =======================
GITHUB_TOKEN=your_github_token
GITHUB_REPO=your_username/spe-platform
BRANCH=main

# =======================
# Monitoring
# =======================
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_PASSWORD=admin

# =======================
# Application Settings
# =======================
DATA_DIR=./data
LOG_DIR=./logs
MODEL_PATH=./pricing_model.pkl
